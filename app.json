{
  "expo": {
    "name": "RestEasy",
    "slug": "resteasy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1D3A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.resteasy.app",
      "buildNumber": "1",
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "RestEasy n'accède pas à la caméra. Cette clé est requise par certaines bibliothèques tierces incluses dans l'application.",
        "NSMicrophoneUsageDescription": "RestEasy utilise la session audio pour la lecture de sons de relaxation en arrière-plan. Le microphone n'est pas enregistré.",
        "NSHealthShareUsageDescription": "RestEasy lit vos données de sommeil Apple Santé pour pré-remplir votre journal et améliorer votre suivi du programme TCC-I.",
        "NSHealthUpdateUsageDescription": "RestEasy enregistre vos séances de pleine conscience (exercices de respiration) dans Apple Santé.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1D3A"
      },
      "package": "com.resteasy.app",
      "versionCode": 1,
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0B1D3A",
          "sounds": [],
          "mode": "production"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4337d5be-b498-47bb-9a70-ce30ceb2cb88"
      }
    },
    "owner": "chemicaltof"
  }
}
