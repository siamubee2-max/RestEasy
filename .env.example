# RestEasy — Variables d'environnement
# Copiez ce fichier : cp .env.example .env
# Ne committez jamais le fichier .env

# ─── Supabase ───────────────────────────────────────────────────────────────
# Obtenez ces valeurs sur app.supabase.com → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── RevenueCat ─────────────────────────────────────────────────────────────
# Obtenez ces clés sur app.revenuecat.com → Project → API Keys
EXPO_PUBLIC_RC_API_KEY_IOS=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_RC_API_KEY_ANDROID=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── PostHog ────────────────────────────────────────────────────────────────
# Obtenez ces valeurs sur app.posthog.com → Project Settings → API Keys
EXPO_PUBLIC_POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ─── Sentry ─────────────────────────────────────────────────────────────────
# Obtenez ces valeurs sur sentry.io → Settings → Projects → resteasy
EXPO_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org-slug

# ─── ElevenLabs (côté serveur uniquement — Supabase Edge Functions) ──────────
# Ne pas préfixer EXPO_PUBLIC_ — cette clé ne doit jamais être exposée côté client
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
